{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v pi >/dev/null 2>&1 && echo \"[pi-plugin] pi: ready ($(pi --version 2>/dev/null || echo unknown))\" || echo \"[pi-plugin] pi: not found (install: npm i -g @mariozechner/pi-coding-agent)\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pi-caller-inject.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pi-cc cleanup 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
